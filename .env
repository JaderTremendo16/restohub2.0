

# Red interna de Docker privada entre contenedores. 
COMPOSE_PROJECT_NAME=restohub
NETWORK_NAME=restohub-network

# Puertos expuestos al exterior en el cuál solo el puerto 4000 es para el usuario final (los demás para desarrollo)
GATEWAY_PORT=4000

INGREDIENTS_PORT=4001
MENU_PORT=4002
INVENTORY_PORT=4003
PAIS_RESTAURANTE_PORT=4005
STAFF_PORT=4006



# RabbitMQ: El broker de mensajes. El puerto 5672 es donde los servicios publican y consumen mensajes. 
RABBITMQ_USER=restohub
RABBITMQ_PASS=restohub123
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# Postgres: solo para definir la imagen base
POSTGRES_VERSION=16-alpine
POSTGRES_PORT=5432

