# Configuración Servidor y DB
PORT=3001
DB_HOST=orders-db
DB_NAME=db_order_service
DB_USER=orders_user
DB_PASSWORD=your_password_here

# Configuración del contenedor de Base de datos (Para Docker Compose)
POSTGRES_USER=orders_user
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=db_order_service

# Externos
MP_ACCESS_TOKEN=your_token_here
MP_PUBLIC_KEY=your_key_here
FRONTEND_URL=your_frontend_url_here
RABBITMQ_URL=amqp://restohub:your_password_here@rabbitmq:5672

PAYPAL_CLIENT_ID=your_paypal_id_here
PAYPAL_CLIENT_SECRET=your_paypal_secret_here
PAYPAL_MODE=sandbox
